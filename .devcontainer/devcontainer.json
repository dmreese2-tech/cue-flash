{
  "name": "Cue Flash Demo",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "postCreateCommand": "npm install",
  "postStartCommand": "(nohup node server.js > /tmp/cueflash.log 2>&1 &) ",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Cue Flash Demo",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  }
}
